# --- CẤU HÌNH REDIS (Cho BullMQ) ---
# Nếu chạy local mặc định thì không cần sửa
# --- CẤU HÌNH REDIS CLOUD ---
# Host: Chỉ lấy phần tên miền, bỏ phần :port phía sau đi
REDIS_HOST= 
# Port: Lấy số cổng sau dấu hai chấm
REDIS_PORT= 
# Password: Copy y nguyên mật khẩu vào
REDIS_PASSWORD= 

# --- CẤU HÌNH BLOCKCHAIN (Polygon Amoy) ---
# 1. RPC URL: Copy từ file .env cũ của Contract hoặc dùng link public này
RPC_URL=" "
# 2. Private Key: VÍ WORKER (Ví Admin)
# Đây là ví sẽ trả tiền gas cho việc Mint vé và Check-in.
PRIVATE_KEY=" "
# 3. Địa chỉ Contract: Lấy từ kết quả Deploy ở bước trước
# Ví dụ: 0xD491...
CONTRACT_ADDRESS= "" 

# --- CẤU HÌNH WORKER (Batching Strategy) ---
# Số lượng vé tối đa trong 1 lần gom (Batch Size)
BATCH_SIZE=10
# Thời gian chờ tối đa (ms) trước khi buộc phải mint (ví dụ: 10 giây)
BATCH_TIMEOUT=10000

# --- CHIẾN LƯỢC CHECK-IN (Ưu tiên tiết kiệm Gas) ---
# Gom tối đa 50 vé hoặc đợi 60 giây thì mới Đồng bộ lên Chain
CHECKIN_BATCH_SIZE=50
CHECKIN_BATCH_TIMEOUT=60000

# Cấu hình IPFS (Pinata) - Để sau, tạm thời chưa cần
PINATA_API_KEY=xxx
PINATA_SECRET_KEY=xxx

# --- CẤU HÌNH RELAYER BUY WORKER ---
RELAYER_QUEUE_NAME=relayer-buy-queue
RELAYER_DLQ_QUEUE_NAME=relayer-buy-dlq
RELAYER_ATTEMPTS=5
RELAYER_BACKOFF_DELAY=5000
RELAYER_CONCURRENCY=1

# Backend / webhook endpoints cho worker relayer
BE_API_URL=http://localhost:3001
RELAYER_ORDER_LOOKUP_PATH=/api/v1/internal/orders/
RELAYER_RESULT_PATH=/api/v1/webhooks/internal/relayer-buy-result
INTERNAL_WEBHOOK_SECRET=xxx

# Nếu USDT trên chain khác 6 decimals thì override ở đây
USDT_DECIMALS=6

